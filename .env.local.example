# ─── Web app (required) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Production app URL (Vercel sets VERCEL_URL automatically; override if needed)
# NEXT_PUBLIC_APP_URL=https://life-system-rho.vercel.app

# ─── Vercel server only (CLI API routes) ─────────────────────────────────────
# Supabase → Project Settings → API → service_role (never expose to browser)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Local CLI / MCP ──────────────────────────────────────────────────────────
# Required on Vercel for MCP capture (never accepted from client requests)
ANTHROPIC_API_KEY=sk-ant-api03-...
# AOS_API_URL=https://life-system-rho.vercel.app
# AOS_VAULT_PATH=~/vault
# AOS_SYNC_INTERVAL_MS=900000
